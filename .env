# Copy to .env and fill values

# Server port
PORT=3000

# External email API
# Development: use localhost
# Production: use your production domain
EMAIL_API_BASE=https://seaofbeer.com
EMAIL_API_SEND_PATH=/api/Events/create
EMAIL_API_ALLOW_SELF_SIGNED=false

# Frontend API endpoints
VITE_API_BASE=https://seaofbeer.com
VITE_API_URL=https://seaofbeer.com/api
