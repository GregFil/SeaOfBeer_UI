# Copy to .env and fill values

# Server port
PORT=3000

# External email API
# Production: EMAIL_API_BASE=https://seaofbeer.com
EMAIL_API_BASE=https://localhost:7079
EMAIL_API_SEND_PATH=/api/Events/create
# Production: EMAIL_API_ALLOW_SELF_SIGNED=false
EMAIL_API_ALLOW_SELF_SIGNED=true

# Frontend API endpoints (only used in development)
# For production, use .env.production with relative paths:
# VITE_API_BASE=/api
# VITE_API_URL=/api
VITE_API_BASE=https://localhost:7079
VITE_API_URL=https://localhost:7079/api
